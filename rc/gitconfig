[user]
    name = Horațiu Mlendea
    email = io.github.hmlendea.cnzq9@SimpleLogin.fr
[core]
    hooksPath = ~/.config/git/hooks
    autocrlf = input
    pager = most
    ignorecase = false
    filemode = false
    askpass = 
    fscache = true
[merge]
    conflictstyle = diff3
[credential]
    helper = cache --timeout=259200
    modalPrompt = false
[push]
    default = current
[pull]
    rebase = true
[diff "astextplain"]
    textconv = astextplain
[rebase]
    autosquash = true
[init]
    defaultBranch = master
[color]
    ui = auto
    diff = auto
    status = auto
    branch = auto
    interactive = true
[color "status"]
    added = green
    changed = red
    untracked = cyan
[help]
    format = html
[http]
    verifySsl = false
    sslVerify = false
[alias]
    acp = "!f() { git add . && git commit -m \"$*\" && git push; }; f"
    branches = !git branch -vv
    cleanup = "!f() { \
        BASE=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'); \
        git fetch -p && \
        git branch --merged origin/$BASE | grep -vE \"^\\*|$BASE\" | xargs -r git branch -d; \
    }; f"
    deltag = !git tag -d $1 &&  git push origin :refs/tags/$1
    jeff = !git diff --ignore-space-at-eol -b -w --ignore-blank-lines
    lg = !git --no-pager log --reverse --pretty='%C(yellow)%h %C(bold blue)%<(15,trunc)%an%Creset %Cgreen%ad%Creset %s%C(auto)%d%Creset' --date=format:'%Y/%m/%d %H:%M' -n32
    newbranch = "!f() { git branch \"$1\" && git push -u origin \"$1\" && git checkout \"$1\"; }; f"
    remotes = !git remote -vv
    stashes = !git stash list
    sync = !git pull && git cleanup && git push
    undo = !git reset HEAD^
    unstage = !git reset HEAD --
